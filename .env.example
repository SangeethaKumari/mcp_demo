#
# Since most our projects will need the configuration
# utility, this fixes the directory where to find them.
#
export BOOTCAMP_ROOT_DIR="/home/skumaran/repo/ai_agents_bootcamp/mcp_customer_support_demo"

#
# Project's Python executable path
# Points to the virtual environment's Python interpreter
#
export PROJECT_PYTHON="/home/skumaran/repo/ai_agents_bootcamp/mcp_customer_support_demo/.venv/bin/python"

#
# Precaution, needed for some IDEs
# to recognize that the main svlearn library code
# is in the src/ sub-directory
